           </div>
           <div class="card">
            <div class="card-header">
              <div class="card-title d-flex justify-content-between align-items-center w-100"> 
                <h5 class="mb-0">Records</h5>
              </div>
            </div>
              <div class="card-body">
                
                <table id="table" class="table table-bordered">
                  <thead> 
                    <tr>
                      <th>Requestioner</th>
                      <th>Contact No</th>
                      <th>Description</th>
                      <th>Status</th>
                      <th>SMS Notification</th>
                      <th>Date Submitted</th>
                      <!-- <th>Action</th> -->
                    </tr>
                  </thead>
                  
                 
                  <tbody>
                    <% if(locals.received_docs) { %>
                      <% received_docs.forEach((received_doc) => { %>
                      <tr>        
                                <td><%= received_doc.requestioner %></td>
                                <td><%= received_doc.contact_no %></td>
                                <td><%= received_doc.description %></td>
                                <td><%= received_doc.status %></td>
                                <td> <span class="badge <%= received_doc.sms_status === 'pending' ? 'badge-danger' : 'badge-success'%>"> <%= received_doc.sms_status %>  </span> </td>
                                <td><%= new Date(received_doc.date_submitted).toLocaleDateString('en-US', { 
                                  year: 'numeric', 
                                  month: 'long', 
                                  day: 'numeric' 
                              }) %></td>

                              <!-- <td>
                                <button class="btn btn-secondary btn-sm edit-btn"  data-toggle="modal" data-target="#updateDocumentModal"  data-id="<%= received_doc.id %>">
                                  <i class="fas fa-cogs"></i>
                                </button>
                              </td> -->
                     </tr>

                    <% }) %>
                    <% } %>
                 
                  </tbody>
                </table>
            

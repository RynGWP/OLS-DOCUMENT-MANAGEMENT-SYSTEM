<!-- Add Document Modal -->
<div class="modal fade" id="addDocumentModal" tabindex="-1">
  <div class="modal-dialog modal-lg">
    <div class="modal-content shadow-lg rounded">

      <!-- Header -->
      <div class="modal-header bg-primary text-white">
        <h5 class="modal-title">
          <i class="fas fa-file-alt mr-2"></i> Add New Document
        </h5>
        <button type="button" class="close text-white" data-dismiss="modal">
          <span>&times;</span>
        </button>
      </div>

      <!-- Body -->
      <div class="modal-body">
        <form id="addDocumentForm" action="/createDocs" method="POST">

          <div class="row">

            <!-- Tracking Number -->
            <div class="col-md-6 mb-3">
              <label class="font-weight-bold">Tracking Number</label>
              <input type="text" class="form-control" name="tracking_no" 
              placeholder="Enter tracking number" required>
            </div>

            <!-- Requestioner -->
            <div class="col-md-6 mb-3">
              <label class="font-weight-bold">Requisitioner</label>
              <input type="text" class="form-control" name="requisitioner" 
              placeholder="Enter requisitioner name" required>
            </div>

            <!-- Email -->
            <div class="col-md-6 mb-3">
              <label class="font-weight-bold">Email Address</label>
              <input type="email" class="form-control" name="email" 
              placeholder="example@email.com" required>
            </div>

            <!-- Contact -->
            <div class="col-md-6 mb-3">
              <label class="font-weight-bold">Contact Number</label>
              <input type="text" class="form-control" name="contact_no"
              placeholder="09123456789" required>
            </div>

            <!-- Folder -->
            <div class="col-md-6 mb-3">
              <label class="font-weight-bold">Color / Folder Number</label>
              <input type="text" class="form-control" name="folder_number"
              placeholder="Folder Code / Color" required>
            </div>

            <!-- Status -->
            <div class="col-md-6 mb-3">
              <label class="font-weight-bold">Status</label>
              <select class="form-control" name="status" required>
                <option value="For Review">For Review</option>
                <option value="Ready to Release">Ready to Release</option>
                <option value="Released">Released</option>
              </select>
            </div>

            <!-- Description -->
            <div class="col-md-12 mb-3">
              <label class="font-weight-bold">Description</label>
              <textarea class="form-control" name="description" rows="3"
              placeholder="Enter document description..." required></textarea>
            </div>

            <!-- Date Submitted -->
            <div class="col-md-6 mb-3">
              <label class="font-weight-bold">Date Submitted</label>
              <input type="date" class="form-control" name="date_submitted" required>
            </div>

          </div>

          <!-- Footer -->
          <div class="modal-footer border-top pt-3">
            <button type="button" class="btn btn-outline-secondary" data-dismiss="modal">
              <i class="fas fa-times"></i> Cancel
            </button>

            <button type="submit" class="btn btn-success">
              <i class="fas fa-save"></i> Save Document
            </button>
          </div>

        </form>
      </div>

    </div>
  </div>
</div>



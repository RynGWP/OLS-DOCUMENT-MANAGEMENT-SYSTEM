<!-- fetching data from backend to from backend to frontend-->
<script>
  // Enhanced table refresh function with better error handling
function fetchAndUpdateDocuments() {
  // Store current SMS statuses before fetching new data
  const currentSmsStatuses = {};
  
  if ($.fn.DataTable.isDataTable('#table')) {
    const table = $('#table').DataTable();
    table.rows().every(function() {
      const rowData = this.data();
      // Find document ID from the action button
      const actionButton = rowData[6];
      const idMatch = actionButton.match(/data-id="([^"]+)"/);
      if (idMatch && idMatch[1]) {
        const docId = idMatch[1];
        // Store the SMS status (extract text from the badge)
        const smsStatusHtml = rowData[4];
        const tempDiv = document.createElement('div');
        tempDiv.innerHTML = smsStatusHtml;
        const smsStatus = tempDiv.textContent.trim();
        currentSmsStatuses[docId] = smsStatus;
      }
    });
  }
  
  axios.get(window.location.pathname)  // Use current path instead of hardcoded '/receivedDocs'
    .then(function(response) {
      // Check if we got HTML instead of JSON
      if (typeof response.data === 'string' && response.data.includes('<!DOCTYPE html>')) {
        console.log('Received HTML response instead of JSON. Using DOM parsing.');
        
        // Create a temporary DOM element to parse the HTML
        const tempDiv = document.createElement('div');
        tempDiv.innerHTML = response.data;
        
        // Extract table rows from the HTML response
        const tableRows = tempDiv.querySelectorAll('#table tbody tr');
        
        // Process the table data
        processTableFromHTML(tableRows, currentSmsStatuses);
        return;
      }
      
      // Process JSON response
      const data = response.data;
      
      // Get a reference to the DataTable
      const table = $('#table').DataTable();
      
      // Store current page and search before clearing
      const currentPage = table.page();
      const currentSearch = table.search();
      
      // Get current record count to detect if records were removed
      const previousRowCount = table.data().length;
      
      // Clear existing table data
      table.clear();
      
      // Track SMS status changes
      const smsStatusChanges = [];
      
      // Add new data
      if (data && data.length > 0) {
        data.forEach(function(doc) {
          const formattedDate = new Date(doc.date_submitted).toLocaleDateString('en-US', {
            year: 'numeric',
            month: 'long',
            day: 'numeric'
          });
          
          const smsStatusBadge = doc.sms_status === 'pending' ? 
            '<span class="badge badge-danger">pending</span>' : 
            '<span class="badge badge-success">' + doc.sms_status + '</span>';
          
          // Check if SMS status changed from pending to something else
          if (currentSmsStatuses[doc.id] === 'pending' && doc.sms_status !== 'pending') {
            smsStatusChanges.push({
              id: doc.id,
              requestioner: doc.requestioner,
              oldStatus: currentSmsStatuses[doc.id],
              newStatus: doc.sms_status
            });
          }
            
          const actionButton = '<button class="btn btn-secondary btn-sm edit-btn" data-toggle="modal" ' +
            'data-target="#updateDocumentModal" data-id="' + doc.id + '">' +
            '<i class="fas fa-cogs"></i></button>';
            
          table.row.add([
          doc.tracking_no,
          doc.requestioner,
          doc.contact_no || '',
          doc.description,
          doc.table_location,           
          doc.status,
          smsStatusBadge,
          formattedDate,
          actionButton
        ]);
        });
      }
      
      // Show toaster notifications for SMS status changes
      if (smsStatusChanges.length > 0) {
        smsStatusChanges.forEach(change => {
          toastr.success(`SMS to ${change.requestioner} successfully ${change.newStatus}!`, 'SMS Notification');
        });
      }
      
      // Check if records were removed (SMS sent)
      const currentRowCount = data.length;
      if (previousRowCount > currentRowCount && previousRowCount > 0) {
        // Records were removed, likely due to SMS being sent
        const removedCount = previousRowCount - currentRowCount;
        toastr.success(`${removedCount} notification${removedCount > 1 ? 's' : ''} sent successfully!`, 'SMS Notifications');
      }
      
      // Redraw the table with new data
      table.draw(false); // false to maintain paging position
      
      // Adjust page if needed (in case all records on current page were removed)
      const pageInfo = table.page.info();
      if (currentPage > 0 && pageInfo.pages < currentPage + 1) {
        table.page('last').draw('page');
      } else {
        table.page(currentPage).draw('page');
      }
      
      // Restore search
      if (currentSearch) {
        table.search(currentSearch).draw();
      }
      
      // Reattach event listeners to edit buttons
      attachEditButtonListeners();
    })
    .catch(function(error) {
      console.error('Error fetching documents:', error);
      
      // More detailed error logging
      if (error.response) {
        // The request was made and the server responded with a status code
        // that falls out of the range of 2xx
        console.error('Error data:', error.response.data);
        console.error('Error status:', error.response.status);
        console.error('Error headers:', error.response.headers);
      } else if (error.request) {
        // The request was made but no response was received
        console.error('Error request:', error.request);
      } else {
        // Something happened in setting up the request that triggered an Error
        console.error('Error message:', error.message);
      }
      
      // Try an alternative approach - refresh the whole page after multiple failures
      window.refreshAttempts = (window.refreshAttempts || 0) + 1;
      if (window.refreshAttempts > 3) {
        console.log('Multiple refresh attempts failed. Reloading page...');
        window.refreshAttempts = 0;
        // window.location.reload();
      } else {
        
        // Try again after a delay
        setTimeout(fetchAndUpdateDocuments, 3000);
      }
    });
}

// Function to process table data from HTML response
function processTableFromHTML(tableRows, currentSmsStatuses) {
  // Get a reference to the DataTable
  const table = $('#table').DataTable();
  
  // Store current page and search before clearing
  const currentPage = table.page();
  const currentSearch = table.search();
  
  // Get current record count
  const previousRowCount = table.data().length;
  
  // Clear existing table data
  table.clear();
  
  // Track SMS status changes
  const smsStatusChanges = [];
  
  // Add new data from HTML rows
  if (tableRows && tableRows.length > 0) {
    tableRows.forEach(function(row) {
      const cells = row.querySelectorAll('td');
      if (cells.length >= 7) {
        // Extract document ID from action button
        const actionButton = cells[6].innerHTML;
        const idMatch = actionButton.match(/data-id="([^"]+)"/);
        
        if (idMatch && idMatch[1]) {
          const docId = idMatch[1];
          
          // Extract SMS status from the badge
          const smsStatusCell = cells[4];
          const smsStatusBadge = smsStatusCell.querySelector('.badge');
          const smsStatus = smsStatusBadge ? smsStatusBadge.textContent.trim() : '';
          
          // Check if SMS status changed from pending to something else
          if (currentSmsStatuses[docId] === 'pending' && smsStatus !== 'pending') {
            smsStatusChanges.push({
              id: docId,
              requestioner: cells[0].textContent.trim(),
              oldStatus: currentSmsStatuses[docId],
              newStatus: smsStatus
            });
          }
        }
        
          table.row.add([
          // cells[0].textContent.trim(),          // Column 0
          // cells[1].textContent.trim(),          // Column 1
          // cells[2].textContent.trim(),          // Column 2
          // cells[3].textContent.trim(),          // Column 3
          // cells[4].textContent.trim(),          // Column 4
          // cells[5].textContent.trim(),          // Column 5
          // cells[6].textContent.trim(),          // Column 6
          // cells[7].textContent.trim(),          // Column 7
          doc.contact_no || '',       // Column 1
          doc.description,            // Column 2
          doc.table_location,                  // Column 3 
          doc.status,                 // Column 4
          smsStatusBadge,             // Column 5
          formattedDate,              // Column 6
          actionButton                // Column 7
        ]);
      }
    });
  }
  
  // Show toaster notifications for SMS status changes
  if (smsStatusChanges.length > 0) {
    smsStatusChanges.forEach(change => {
      toastr.success(`SMS to ${change.requestioner} successfully ${change.newStatus}!`, 'SMS Notification');
    });
  }
  
  // Check if records were removed (SMS sent)
  const currentRowCount = tableRows.length;
  if (previousRowCount > currentRowCount && previousRowCount > 0) {
    // Records were removed, likely due to SMS being sent
    const removedCount = previousRowCount - currentRowCount;
    toastr.success(`${removedCount} notification${removedCount > 1 ? 's' : ''} sent successfully!`, 'SMS Notifications');
  }
  
  // Redraw the table with new data
  table.draw(false);
  
  // Restore page and search
  if (currentPage) {
    table.page(currentPage).draw('page');
  }
  if (currentSearch) {
    table.search(currentSearch).draw();
  }
  
  // Reattach event listeners to edit buttons
  attachEditButtonListeners();
}

// Function to attach event listeners to edit buttons
function attachEditButtonListeners() {
  const editButtons = document.querySelectorAll(".edit-btn");
  
  editButtons.forEach(button => {
    button.addEventListener("click", function() {
      const id = this.getAttribute("data-id");
      document.getElementById("edit_id").value = id;
    });
  });
}

// Initial data fetch when document is ready
$(document).ready(function() {
  console.log('Document ready, initializing table refresh');
  
  // First load
  fetchAndUpdateDocuments();
  
  // Set up polling interval (every 10 seconds) - increased interval to reduce server load
  const refreshInterval = setInterval(function() {
    console.log('Auto-refreshing table data');
    fetchAndUpdateDocuments();
  }, 10000);
  
  // Clear interval if page is hidden/inactive
  document.addEventListener('visibilitychange', function() {
    if (document.hidden) {
      clearInterval(refreshInterval);
      console.log('Page hidden, paused auto-refresh');
    } else {
      console.log('Page visible, resuming auto-refresh');
      fetchAndUpdateDocuments(); // Refresh immediately
      // Restart interval
      clearInterval(refreshInterval);
      setInterval(function() {
        console.log('Auto-refreshing table data');
        fetchAndUpdateDocuments();
      }, 10000);
    }
  });
  
  // Listen for document status changes
  $('#updateDocumentModal form').on('submit', function(e) {
    console.log('Form submitted, will refresh table');
    // Let the form submit normally, then update after a slight delay
    setTimeout(fetchAndUpdateDocuments, 1000);
  });
  
  // Listen for new document additions
  $('#addDocumentModal form').on('submit', function(e) {
    console.log('New document added, will refresh table');
    // Let the form submit normally, then update after a slight delay
    setTimeout(fetchAndUpdateDocuments, 1000);
  });
});
</script>





                      <% if(locals.DeedOfDonation_data && DeedOfDonation_data.length > 0) { %>
                          <table id="multi-filter-select" class="display table table-striped table-hover">
                              <thead>
                                  <tr>
                                    <th>Donor</th>
                                    <th>Donee</th>
                                    <th>Donation</th>
                                    <th>Unit Cost</th>
                                    <th>Date Acquired</th>
                                    <th>File Location</th>
                                    <th>Action</th>
                                  </tr>
                              </thead>
                              <tbody>
                                  <% DeedOfDonation_data.forEach(DeedOfDonation_datas => { %>
                                      <tr>
                                          <td><%= DeedOfDonation_datas.donor %></td>
                                          <td><%= DeedOfDonation_datas.donee %></td>
                                          <td><%= DeedOfDonation_datas.donation %></td>
                                          <td><%= DeedOfDonation_datas.unit_cost %></td>
                                          <td><%= new Date(DeedOfDonation_datas.date_acquired).toLocaleDateString('en-US', { 
                                              year: 'numeric', 
                                              month: 'long', 
                                              day: 'numeric' 
                                          }) %></td>

                                          <td><%= DeedOfDonation_datas.file_location %></td>
                                          <!-- action button -->
                                        <td class="d-flex align-items-center">



                                            <!-- Edit Button -->
                                            <button type="button"
                                            class="btn btn-primary btn-sm text-primary edit-btn"
                                            data-bs-toggle="modal"
                                            data-bs-target="#editModal"
                                            data-id="<%= DeedOfDonation_datas.id %>"
                                            data-donor="<%= DeedOfDonation_datas.donor %>"
                                            data-donee="<%= DeedOfDonation_datas.donee %>"
                                            data-donation="<%= DeedOfDonation_datas.donation %>"
                                            data-file_location="<%= DeedOfDonation_datas.file_location %>"
                                            data-unit_cost="<%= DeedOfDonation_datas.unit_cost %>"
                                            data-date_acquired="<%= DeedOfDonation_datas.date_acquired %>"
                                            aria-label="Edit"
                                            style="background: transparent !important; border: none !important;">
                                            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="15" fill="#457b9d" class="bi bi-pencil-square" viewBox="0 0 16 16">
                                                <path d="M15.502 1.94a.5.5 0 0 1 0 .706L14.459 3.69l-2-2L13.502.646a.5.5 0 0 1 .707 0l1.293 1.293zm-1.75 2.456-2-2L4.939 9.21a.5.5 0 0 0-.121.196l-.805 2.414a.25.25 0 0 0 .316.316l2.414-.805a.5.5 0 0 0 .196-.12l6.813-6.814z"/>
                                                <path fill-rule="evenodd" d="M1 13.5A1.5 1.5 0 0 0 2.5 15h11a1.5 1.5 0 0 0 1.5-1.5v-6a.5.5 0 0 0-1 0v6a.5.5 0 0 1-.5.5h-11a.5.5 0 0 1-.5-.5v-11a.5.5 0 0 1 .5-.5H9a.5.5 0 0 0 0-1H2.5A1.5 1.5 0 0 0 1 2.5z"/>
                                            </svg>
                                            </button>


                                          <!-- delete button -->
